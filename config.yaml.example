# This is a reccomended configuration file for beets.
# Change directory and library paths to your own.
# Place this in ~/.config/beets/config.yaml

directory: /mnt/HDD2TB/Music
library: /mnt/HDD2TB/Music/musiclibrary.db

import:
    move: yes
    quiet: yes
    quiet_fallback: skip

match:
    strong_rec_thresh: 0.40
    medium_rec_thresh: 0.50

plugins:
  - chroma
  - spotify
  - deezer
  - fromfilename
  - duplicates

duplicates:
    keys: [artist, title]
    tiebreak:
        items: [bitrate]  # Choose the order of items to break ties.
