# Telegram Bot API token (from @BotFather). Keep secret.
TELEGRAM_BOT_TOKEN=
# OPTIONAL Path to the playlist file (m3u format), can be empty if the tracks imported with beets should not be stored in a playlist.
# Example: M3U_PLAYLIST_PATH=/mnt/HDD/Music/Playlists/playlist.m3u
M3U_PLAYLIST_PATH=
# Where incoming audio is saved before beets import.
DOWNLOADS_DIR_PATH=./downloads
# Comma-separated chat ids only — no spaces (not even after commas).
# Group/supergroup ids are usually negative; private chats are positive.
# Example: WHITELIST_CHAT_IDS=-1001234567890,-1009876543210
WHITELIST_CHAT_IDS=
# Python logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

